rules_version = '2';

// Purebreed security model, in one sentence: anyone can browse products and
// place an order, but only the signed-in admin can change product data,
// read the order list, or change an order's status.
//
// This keeps customer PII (phone/address) out of public reads, while still
// allowing the guest-checkout flow the site is built around.

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null;
      // With a single admin account this is enough. If you add more
      // Firebase Auth users later and want to restrict this to just you,
      // swap the line above for:
      //   return request.auth != null && request.auth.token.email == "you@example.com";
    }

    match /products/{productId} {
      // Public catalog: readable by everyone (customers browse with no
      // login). Only the admin can create/edit/delete.
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Guest checkout: anyone can create an order, but the shape is
      // validated so a client can't forge totals or slip in extra fields.
      allow create: if request.resource.data.keys().hasAll(
                        ['orderNumber','status','customer','deliveryMethod','items','subtotal','deliveryFee','total','payment']
                      )
                    && request.resource.data.status == 'pending'
                    && request.resource.data.total is number
                    && request.resource.data.items is list
                    && request.resource.data.items.size() > 0;

      // Customer data (phone, address) is only readable by the admin —
      // never exposed to the public, per the site's privacy policy.
      allow read, update: if isAdmin();
      allow delete: if false; // keep an audit trail; cancel via status instead
    }

    match /wholesale_requests/{requestId} {
      // B2B quote requests: same pattern as orders — anyone (no login) can
      // submit one, but only the admin can read the list back, since it
      // contains a phone number and company name.
      allow create: if request.resource.data.keys().hasAll(
                        ['name','phone','partnershipType','status']
                      )
                    && request.resource.data.status == 'new';
      allow read, update: if isAdmin();
      allow delete: if false;
    }
  }
}